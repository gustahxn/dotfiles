":"$(refresh)"},{"command":"vscode-containers.volumes.remove","title":"Remove...","category":"Container Volumes"},{"command":"vscode-containers.help","title":"Container Help","category":"Containers","icon":"$(question)"},{"command":"vscode-containers.help.reportIssue","title":"Report Issue","category":"Containers"},{"command":"vscode-containers.help.openWalkthrough","title":"Open Container Tools Extension Walkthrough","category":"Containers"},{"command":"vscode-containers.chooseContainerRuntime","title":"Choose container runtime...","category":"Containers","icon":"$(tools)"},{"command":"vscode-containers.askCopilot","title":"Ask Copilot","category":"Containers"},{"command":"vscode-containers.contexts.use","title":"Use","category":"Docker Contexts","icon":"$(check)"},{"command":"vscode-containers.contexts.remove","title":"Remove...","category":"Docker Contexts"},{"command":"vscode-containers.contexts.inspect","title":"Inspect","category":"Docker Contexts"},{"command":"vscode-containers.contexts.configureExplorer","title":"Configure Explorer...","category":"Docker Contexts","icon":"$(settings-gear)"},{"command":"vscode-containers.contexts.refresh","title":"Refresh","category":"Docker Contexts","icon":"$(refresh)"},{"command":"vscode-containers.contexts.help","title":"Docker Context Help","category":"Docker Contexts","icon":"$(question)"},{"command":"vscode-containers.activateContainerRuntimeProviders","title":"Activate Container Runtime Providers...","category":"Containers"},{"command":"vscode-containers.activateRegistryProviders","title":"Activate Registry Providers...","category":"Containers"}],"views":{"containersView":[{"id":"vscode-containers.views.containers","name":"Containers","icon":"resources/ContainerTools.svg"},{"id":"vscode-containers.views.images","name":"Images","icon":"resources/ContainerTools.svg"},{"id":"vscode-containers.views.registries","name":"Registries","icon":"resources/ContainerTools.svg"},{"id":"vscode-containers.views.networks","name":"Networks","icon":"resources/ContainerTools.svg","visibility":"collapsed"},{"id":"vscode-containers.views.volumes","name":"Volumes","icon":"resources/ContainerTools.svg","visibility":"collapsed"},{"id":"vscode-containers.views.dockerContexts","name":"Docker Contexts","icon":"resources/ContainerTools.svg","visibility":"collapsed"},{"id":"vscode-containers.views.help","name":"Help and Feedback","icon":"resources/ContainerTools.svg"}]},"viewsContainers":{"activitybar":[{"icon":"resources/ContainerTools.svg","id":"containersView","title":"Containers"}]},"walkthroughs":[{"id":"containersStart","title":"Getting Started with Container Tools","featuredFor":["Dockerfile","Containerfile","compose.yaml","docker-compose.yml","docker-compose.yaml","compose.yml"],"description":"Learn about Docker and the Container Tools extension for Visual Studio Code","steps":[{"id":"chooseContainerRuntime","title":"Choose your Container Runtime","completionEvents":["onCommand:vscode-containers.chooseContainerRuntime"],"description":"The Container Tools extension supports multiple container runtimes. Choose the one you want to use - you can change this anytime.\n[Choose Container Runtime](command:vscode-containers.chooseContainerRuntime)","media":{"markdown":"resources/walkthroughs/empty.md"}},{"id":"openFolder","title":"Open a Workspace Folder","completionEvents":["onCommand:workbench.action.files.openFolder"],"when":"workspaceFolderCount == 0 && !isMac","description":"Open a workspace folder to get started with Container Tools extension features.\n[Open Folder](command:workbench.action.files.openFolder)","media":{"markdown":"resources/walkthroughs/empty.md"}},{"id":"openFolderMac","title":"Open a Workspace Folder","completionEvents":["onCommand:workbench.action.files.openFileFolder"],"when":"workspaceFolderCount == 0 && isMac","description":"Open a workspace folder to get started with Container Tools extension features.\n[Open Folder](command:workbench.action.files.openFileFolder)","media":{"markdown":"resources/walkthroughs/empty.md"}},{"id":"scaffold","title":"Add Docker Files to Workspace","completionEvents":["onCommand:vscode-containers.configure","onCommand:vscode-containers.configureCompose"],"when":"workspaceFolderCount > 0","description":"A Dockerfile contains the instructions to assemble an image containing your app and its dependencies. Using this image to run your app in a container creates a production-like, reproducible runtime environment.\n\nIntelliSense support for authoring your Dockerfile is provided.\n[Add Docker Files](command:vscode-containers.configure)","media":{"image":"https://github.com/microsoft/vscode-containers/raw/main/resources/walkthroughs/1g-addDockerFiles.gif","altText":"Modifying Dockerfiles"}},{"id":"buildImage","title":"Build an Image","completionEvents":["onCommand:vscode-containers.images.build"],"when":"workspaceFolderCount > 0","description":"The Container Tools extension makes it simple to build your image.\n[Build Image](command:vscode-containers.images.build)","media":{"image":"https://github.com/microsoft/vscode-containers/raw/main/resources/walkthroughs/2g-buildImage.gif","altText":"Building a container image"}},{"id":"runContainer","title":"Run a Container","completionEvents":["onCommand:vscode-containers.images.run","onCommand:vscode-containers.compose.up","onCommand:vscode-containers.compose.up.subset","onCommand:vscode-containers.compose.down.subset"],"description":"You can run any image on your system including those you've built with a Dockerfile.\n[Run Image](command:vscode-containers.images.run)","media":{"image":"https://github.com/microsoft/vscode-containers/raw/main/resources/walkthroughs/3g-runContainers.gif","altText":"Running a container"}},{"id":"containerExplorer","title":"Use the Container Explorer","completionEvents":["onView:vscode-containers.views.containers","onCommand:workbench.view.extension.containersView"],"description":"The Container Explorer makes it easy to manage, troubleshoot, and deploy containerized applications. The Container Explorer shows a number of container resources such as containers, images, volumes, networks, and container registries.\n\nThe right-click menu provides access to commonly used commands for each resource type.\n[Open Container Explorer](command:vscode-containers.views.containers.focus)","media":{"image":"https://github.com/microsoft/vscode-containers/raw/main/resources/walkthroughs/4g-useExplorer.gif","altText":"Using the Container Explorer"}},{"id":"pushImage","title":"Push an Image to a Container Registry","completionEvents":["onCommand:vscode-containers.images.push"],"description":"The Container Tools Extension allows you to push your container image to Docker Hub, Azure Container Registry and other registry providers.\n[Push an Image](command:vscode-containers.images.push)","media":{"image":"https://github.com/microsoft/vscode-containers/raw/main/resources/walkthroughs/5g-pushImage.gif","altText":"Pushing an image to a container registry"}},{"id":"azDeploy","title":"Deploy to Azure App Service","completionEvents":["onCommand:vscode-containers.registries.deployImageToAzure","onCommand:vscode-containers.registries.deployImageToAca"],"description":"The Container Tools extension helps you deploy your containerized applications and take advantage of a fully-managed platform using Azure App Service. Prior to deployment, the image must be uploaded to either Azure Container Registry or Docker Hub.\n\nAfter a successful deployment, select **Open Site** in the notification. Your container is running in Azure!\n[Deploy](command:vscode-containers.registries.deployImageToAzure)","media":{"image":"https://github.com/microsoft/vscode-containers/raw/main/resources/walkthroughs/6g-deployToAppSvc.gif","altText":"Deploying to Azure App Service"}},{"id":"learn","title":"Learn More","description":"Great job! You've now completed Getting Started with Container Tools. But don't stop here! There are plenty of ways to become more proficient building containerized applications using the Container Tools extension.\n\nFor example, you can [debug a container](https://code.visualstudio.com/docs/containers/debug-common), or [run multiple containers](https://code.visualstudio.com/docs/containers/docker-compose) at once using Docker Compose.\n\nCheck out our [documentation](https://code.visualstudio.com/docs/containers/overview) to make the most of the Container Tools extension for VS Code!","completionEvents":["onStepSelected"],"media":{"markdown":"resources/walkthroughs/empty.md"}}]}],"languageModelTools":[{"name":"container-tools_get-config","tags":["containers"],"toolReferenceName":"containerToolsConfig","displayName":"Get Container Tools Configuration","modelDescription":"Gets the configuration the user has set for the container and container orchestrator (compose) CLIs, including the correct base commands to use and any environment variables that will be set. This tool **MUST** be called before generating or running any container or container orchestrator CLI commands, to ensure the correct base command is used.","userDescription":"Gets the configuration for the Container Tools extension.","canBeReferencedInPrompt":true,"icon":"$(settings-gear)"}]},"engines":{"vscode":"^1.105.0"},"capabilities":{"virtualWorkspaces":false,"untrustedWorkspaces":{"supported":"limited","description":"Workspace must be trusted in order to perform relevant container actions.","restrictedConfigurations":["containers.commands.build","containers.commands.run","containers.commands.runInteractive","containers.commands.attach","containers.commands.logs","containers.commands.composeUp","containers.commands.composeUpSubset","containers.commands.composeDown","containers.environment","containers.scaffolding.templatePath","containers.containerCommand","containers.composeCommand","containers.containerClient","containers.orchestratorClient"]}},"scripts":{"build":"npm run build:esbuild & npm run build:check","build:esbuild":"node esbuild.m